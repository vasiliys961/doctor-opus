# Doctor Opus v3.42.0 — Environment Variables
# Скопируйте в .env и заполните реальными значениями

# =============================================
# ОБЯЗАТЕЛЬНЫЕ
# =============================================

# OpenRouter API (AI-анализ)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# NextAuth (авторизация)
NEXTAUTH_SECRET=your-random-secret-here
NEXTAUTH_URL=https://doctor-opus.ru

# PostgreSQL (база данных)
POSTGRES_URL=postgres://user:password@db:5432/neondb

# =============================================
# АВТОРИЗАЦИЯ И БЕЗОПАСНОСТЬ
# =============================================

# Администраторы (через запятую)
ADMIN_EMAILS=admin@doctor-opus.ru,support@doctor-opus.ru

# Временный доступ по паре email+пароль для приглашенного пользователя
# (используйте только при необходимости, затем очищайте)
# TEMP_ACCESS_EMAIL=digoxini2001@mail.ru
# TEMP_ACCESS_PASSWORD=Opus!Temp#7392

# Режим гостевого инвайта через общие пароли (вход в обычной форме email+password)
# Включить/выключить режим:
# INVITE_MODE_ENABLED=false
# Пароль для тарифа 500 ₽ и 1000 ₽:
# INVITE_PASSWORD_500=invite-500-secret
# INVITE_PASSWORD_1000=invite-1000-secret
# Валидационная модель Opus для режима validated:
# По умолчанию используется 4.8.
# Для быстрого отката установите: VALIDATED_OPUS_MODEL=4.7
# Допустимые значения: 4.8 (default) / 4.7
# VALIDATED_OPUS_MODEL=4.8
# Опциональный апгрейд для сложных validated-кейсов:
# ENABLE_VALIDATED_FABLE=true
# VALIDATED_FABLE_MODEL=anthropic/claude-fable-5
# Коэффициент к цене validated-режима при выборе Fable (по умолчанию x2):
# VALIDATED_FABLE_COST_MULTIPLIER=2
# Порог "сложного кейса" (если кадров >= порога, предлагаем Fable):
# VALIDATED_COMPLEX_MIN_IMAGES=3
# Порог длины клинического контекста для предложения Fable:
# VALIDATED_COMPLEX_MIN_CONTEXT_CHARS=500
# Ежемесячная ротация паролей (рекомендуется):
# INVITE_ROTATING_SECRET=change-me-very-strong-random-secret
# При наличии INVITE_ROTATING_SECRET генерируются коды вида DO-500-YYYYMM-XXXXX
# и принимаются для текущего + предыдущего месяца.
# Посмотреть актуальные коды можно у admin: GET /api/admin/invite-passwords
# Начисление единиц рассчитывается по CREDIT_PRICE_RUB и выдается 1 раз на email для каждого пароля.

# VIP-пользователи с бесконечным балансом (через запятую)
VIP_EMAILS=admin@doctor-opus.ru,support@doctor-opus.ru
# Дублируется для клиентской стороны (subscription-manager)
NEXT_PUBLIC_VIP_EMAILS=admin@doctor-opus.ru,support@doctor-opus.ru

# Аварийный пароль для входа без БД (только для начальной настройки!)
# ADMIN_PASSWORD=your-strong-admin-password

# JWT время жизни в секундах (по умолчанию 24 часа)
# JWT_MAX_AGE_SECONDS=86400

# Секрет для миграций БД (обязательно задать!)
MIGRATION_SECRET=your-migration-secret-here

# Salt для шифрования данных (обязательно сменить!)
ENCRYPTION_SALT=your-unique-random-salt-at-least-32-chars

# =============================================
# ТРАНСКРИПЦИЯ АУДИО
# =============================================
# Провайдер: assemblyai (по умолчанию) или yandex
# SPEECH_PROVIDER=assemblyai

# AssemblyAI (США) — по умолчанию
ASSEMBLYAI_API_KEY=your-assemblyai-api-key-here

# Yandex SpeechKit (РФ) — альтернатива
# SPEECH_PROVIDER=yandex
# YANDEX_SPEECHKIT_API_KEY=your-iam-token
# YANDEX_SPEECHKIT_FOLDER_ID=your-folder-id

# =============================================
# ОТПРАВКА EMAIL
# =============================================
# Провайдер: smtp (по умолчанию, РФ) или resend (США)
EMAIL_PROVIDER=smtp

# SMTP / Timeweb (РФ) — по умолчанию
SMTP_HOST=smtp.timeweb.ru
SMTP_PORT=465
SMTP_USER=support@doctor-opus.ru
SMTP_PASS=your-smtp-password
SMTP_FROM=Doctor Opus <support@doctor-opus.ru>

# Resend (США) — альтернатива
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=your-resend-api-key-here

# =============================================
# ПЛАТЕЖИ
# =============================================
# По умолчанию (не задано или любое значение кроме payanyway) — Yagoda.
# Для EN / legacy укажите: PAYMENT_PROVIDER=payanyway
# PAYMENT_PROVIDER=yagoda

# Yagoda (https://yagoda.team/integrations/guide) — РФ, чеки на стороне Yagoda
YAGODA_API_TOKEN=
YAGODA_INTEGRATION_TYPE=store
# Опционально: если задан — webhook должен прислать Authorization: Bearer <тот же секрет>
# YAGODA_WEBHOOK_SECRET=

# Курс пополнения (₽ за 1 единицу баланса) и минимальная сумма
CREDIT_PRICE_RUB=2.5
MIN_TOPUP_RUB=250

# Ограничение подключений к подписке:
# true (по умолчанию) — новые пользователи после cutoff не смогут создать оплату.
# false — ограничение отключено.
# SUBSCRIPTION_CLOSE_FOR_NEW_USERS=true

# Полное закрытие оплаты:
# true (по умолчанию) — оплата недоступна для всех аккаунтов.
# false — разрешить оплату и применять остальные ограничения.
# SUBSCRIPTION_PAYMENTS_HARD_CLOSED=true

# Cutoff-дата для определения "новых" пользователей (UTC ISO-8601).
# Аккаунты, созданные после этой даты, будут заблокированы для оплаты,
# если у них нет уже подтверждённой оплаты.
# SUBSCRIPTION_NEW_USERS_CUTOFF_ISO=2026-05-24T19:40:00.000Z

# Email-allowlist, который обходит ограничение (через запятую).
# PAYMENT_ACCESS_ALLOWLIST=owner@doctor-opus.ru,ops@doctor-opus.ru

# Для EN (doctor-opus.online) или полного legacy: раскомментируйте
# PAYMENT_PROVIDER=payanyway

# -----------------------------------------------
# PayAnyWay (Moneta.ru) — при PAYMENT_PROVIDER=payanyway
# -----------------------------------------------
# MNT_ID — ID магазина из кабинета PayAnyWay
PAYANYWAY_MNT_ID=your-mnt-id-here

# Секретный ключ из кабинета PayAnyWay (Настройки → Безопасность → Ключ)
PAYANYWAY_SECRET=your-secret-here

# Номер счёта самозанятого (для фискализации через "Мой налог")
PAYANYWAY_SELLER_ACCOUNT=your-seller-account-here

# ИНН поставщика (самозанятого) — для чека
PAYANYWAY_SUPPLIER_INN=your-inn-here

# Наименование поставщика для чека
PAYANYWAY_SUPPLIER_NAME=ИП Иванов Иван Иванович

# Телефон поставщика для чека (через запятую если несколько)
PAYANYWAY_SUPPLIER_PHONES=+79001234567

# Режим тестовых платежей: 1 = тест, 0 = боевой
PAYANYWAY_TEST_MODE=0

# Витринный storefront-callback (использовать только если он реально подключен)
# По умолчанию выключен для безопасности.
PAYANYWAY_STOREFRONT_ENABLED=false

# Секрет для storefront-callback (обязателен, если storefront включен)
# PAYANYWAY_STOREFRONT_TOKEN=change-me-strong-random-token

# IP-адреса PayAnyWay для whitelist (через запятую, если нужна IP-фильтрация)
# PAYMENT_IP_WHITELIST=213.183.52.0,213.183.52.1

# Секрет для фоновой автосверки pending-платежей (endpoint /api/payment/reconcile)
# PAYMENT_RECONCILE_SECRET=change-me-very-strong-secret

# Bridge-reconcile через API PayAnyWay: автопоиск operationId по MNT_TRANSACTION_ID (payment.id)
# Ключ API (query param key=...) для метода getoperation
# PAYANYWAY_OPERATION_LOOKUP_KEY=your-api-key-here
# Секрет API для подписи lookup md5(account + transaction + secret)
# PAYANYWAY_OPERATION_LOOKUP_SECRET=your-api-secret-here
# Счёт/аккаунт Moneta для lookup (если не задан, используется PAYANYWAY_MNT_ID)
# PAYANYWAY_OPERATION_LOOKUP_ACCOUNT=50174333
# Необязательно: кастомный endpoint lookup
# PAYANYWAY_OPERATION_LOOKUP_ENDPOINT=https://bpa.payanyway.ru/api/getoperation

# -----------------------------------------------
# VTB fallback (полу-ручное подтверждение)
# -----------------------------------------------
# Публичная ссылка/QR-страница VTB для кнопки на странице пакетов
NEXT_PUBLIC_VTB_PAYMENT_URL=https://vtb.paymo.ru/collect-money/qr/?transaction=35214b36-08dc-403e-ae5e-183ad31bafee
# Прямая ссылка на картинку QR (опционально). Если не задано, QR генерируется из NEXT_PUBLIC_VTB_PAYMENT_URL.
# NEXT_PUBLIC_VTB_QR_IMAGE_URL=https://example.com/vtb-qr.png
# Email администратора для алертов по кнопке "Я оплатил"
PAYMENT_ALERT_EMAIL=vasiliys@mail.ru

# =============================================
# БАЗА ДАННЫХ (тонкая настройка)
# =============================================
# DB_POOL_MAX=10
# DB_IDLE_TIMEOUT_MS=30000
# DB_CONNECTION_TIMEOUT_MS=10000

# =============================================
# БИЛЛИНГ
# =============================================
# GUEST_TRIAL_BALANCE=10
# REGISTERED_BONUS=0
# INITIAL_BALANCE=10
# BILLING_SOFT_LIMIT=0
# MAX_SINGLE_DEDUCTION=50
# CLINIC_BILLING_ENABLED=0

# =============================================
# RATE LIMITING
# =============================================
# RL_ANALYSIS_WINDOW_SEC=60
# RL_ANALYSIS_MAX=10
# RL_CHAT_WINDOW_SEC=60
# RL_CHAT_MAX=30
# SECURITY: x-forwarded-for потенциально spoofable.
# Включайте TRUST_X_FORWARDED_FOR=true только если заголовок гарантированно перезаписывается вашим trusted proxy.
# TRUST_X_FORWARDED_FOR=false

# =============================================
# API
# =============================================
# MAX_FILE_SIZE_MB=50
# MAX_AUDIO_SIZE_MB=500
# API_MAX_DURATION_SECONDS=300

# Чат-модель GPT-5.4 в OpenRouter может быть нестабильной (Provider returned error).
# По умолчанию используется безопасный fallback на Sonnet.
# Чтобы принудительно включить GPT-5.4 в чате, установите true:
# ALLOW_GPT52_CHAT=false

# Для генерации протокола (app/api/protocol)
# false (по умолчанию) — gpt52 маршрутизируется в Sonnet.
# ALLOW_GPT52_PROTOCOL=false

# Для поиска клинических рекомендаций (app/api/protocols/search, detailed mode)
# false (по умолчанию) — detailed mode идет через Sonnet.
# ALLOW_GPT52_PROTOCOLS_SEARCH=false

# Для анализов изображений (app/api/analyze/image, optimized mode и выбор gpt52)
# false (по умолчанию) — optimized/gpt52 маршрутизируется в Sonnet.
# ALLOW_GPT52_ANALYZE=false

# =============================================
# ШИФРОВАНИЕ
# =============================================
# PBKDF2_ITERATIONS=100000

# =============================================
# ПОДПИСКА
# =============================================
# NEXT_PUBLIC_SUBSCRIPTION_STRICT_MODE=true
